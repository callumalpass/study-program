{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stup.local/schemas/exercise-attempt.schema.json",
  "title": "Exercise Attempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "exerciseId",
    "attemptId",
    "createdAt",
    "updatedAt",
    "status",
    "exerciseType"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "exercise_attempt"
    },
    "exerciseId": {
      "type": "string",
      "minLength": 1
    },
    "attemptId": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "checked",
        "submitted"
      ]
    },
    "exerciseType": {
      "type": "string",
      "enum": [
        "coding",
        "written"
      ]
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "solutionFile": {
      "type": "string",
      "minLength": 1
    },
    "answerFile": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        },
        "memoryMb": {
          "type": "integer",
          "minimum": 32,
          "maximum": 8192
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "exerciseType": {
            "const": "coding"
          }
        }
      },
      "then": {
        "required": [
          "language",
          "solutionFile"
        ],
        "not": {
          "required": [
            "answerFile"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "exerciseType": {
            "const": "written"
          }
        }
      },
      "then": {
        "required": [
          "answerFile"
        ],
        "not": {
          "required": [
            "solutionFile"
          ]
        }
      }
    }
  ]
}

